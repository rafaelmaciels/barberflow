{
    "InstanceIds": [
        "i-04bfb2984c8a0b7ee"
    ],
    "DocumentName": "AWS-RunShellScript",
    "Parameters": {
        "commands": [
            "cd /var/www/barberflow",
            "cat << 'EOF' > test-email.php",
            "<?php",
            "require 'vendor/autoload.php';",
            "$app = require_once 'bootstrap/app.php';",
            "$kernel = $app->make(Illuminate\\Contracts\\Console\\Kernel::class);",
            "$kernel->bootstrap();",
            "try {",
            "    $companyEmail = \\App\\Models\\Setting::where('key', 'company_email')->value('value');",
            "    echo \\\"Sending to: \\\" . $companyEmail . \\\"\\n\\\";",
            "    Mail::raw('Test email from CLI', function($msg) use ($companyEmail) {",
            "        $msg->to($companyEmail)->subject('Test Barberflow');",
            "    });",
            "    echo \\\"Email sent successfully!\\n\\\";",
            "} catch (\\Exception $e) {",
            "    echo \\\"Error: \\\" . $e->getMessage() . \\\"\\n\\\";",
            "}",
            "EOF",
            "php test-email.php"
        ]
    }
}
